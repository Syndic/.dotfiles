# ── macOS ─────────────────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editors ───────────────────────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ── Claude Code ───────────────────────────────────────────────────────────────────────────────────
